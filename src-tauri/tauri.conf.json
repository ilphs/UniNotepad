{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UniNotepad",
  "version": "0.1.0",
  "identifier": "com.uniedit.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "UniNotepad",
        "width": 1000,
        "height": 700,
        "minWidth": 480,
        "minHeight": 320
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["txt", "md", "log", "csv", "json", "ini", "conf", "cfg", "xml", "yaml", "yml"],
        "name": "Text Document",
        "role": "Editor"
      }
    ]
  }
}
