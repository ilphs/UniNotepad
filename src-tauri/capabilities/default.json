{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core + dialog permissions for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "core:window:allow-close",
    "core:window:allow-set-title",
    "core:app:allow-version",
    "core:event:default",
    "dialog:default",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://uninotepad-xi.vercel.app/*" },
        { "url": "https://github.com/ilphs/UniNotepad/*" }
      ]
    }
  ]
}
